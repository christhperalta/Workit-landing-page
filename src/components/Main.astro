---
import Button from "./Button.astro";
import Card from "./Card.astro";
const white = "#FFF";
const DarkPurple = "#24053E";

const infoArr = [
  {
    number: 1,
    title: "Actionable insights",
    text: `Optimize your products, improve customer satisfaction and stay ahead
          of the competition with our product data analytics.`,
  },

  {
    number: 2,
    title: "Data-driven decisions",
    text: `Make data-driven decisions with our product data analytics. Our
          AI-generated reports help you unlock insights hidden in your product
          data.`,
  },

  {
    number: 3,
    title: "Always affordable",
    text: `Always affordable pricing that scales with your business. Get
          top-quality product data analytics services without hidden costs or
          unexpected fees.`,
  },
];
---

<main class='main'>
  <section class='main-section-1'>
    <section class='main-section-1-container'>
      <Card
        number={infoArr.at(0).number}
        title={infoArr.at(0).title}
        text={infoArr.at(0).text}
      />
      <Card
        number={infoArr.at(1).number}
        title={infoArr.at(1).title}
        text={infoArr.at(1).text}
      />
      <Card
        number={infoArr.at(2).number}
        title={infoArr.at(2).title}
        text={infoArr.at(2).text}
      />
    </section>
  </section>
  <section class='main-section-2'>
    <section class='main-section-2-container'>
      <figure class='main-section-2-container-img'>
        <img src='./assets/images/image-founder.webp' alt='image-founder' />
      </figure>
      <article class='main-section-2-container-article'>
        <h2 class='main-section-2-container-h2'>Be the first to test</h2>
        <p class='main-section-2-container-p'>
          Hi, I'm Louis Graham, the founder of the company. Book a demo call
          with me to become a beta tester for our app and kickstart your
          company. Apply for access below and I’ll be in touch to schedule a
          call.
        </p>
        <Button description='Apply for access' />
      </article>
      <figure class="main-section-2-pattern">
         <img src="./assets/images/bg-pattern-3.svg" alt="bg-pattern-3">
      </figure>
    </section>
  </section>

  <style define:vars={{ white, DarkPurple }}>
    .main-section-1 {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
      height: 45.87rem;
      margin-bottom: 5.75rem;
    }

    .main-section-1-container {
      position: absolute;
      top: -200px;
      display: flex;
      flex-flow: row wrap;
      align-items: center;
      justify-content: center;
      gap: 1.62rem;
      width: 100%;
      padding-top: 26.8rem;
      padding-bottom: 10.69rem;
      background: url("./assets/images/bg-pattern-5.svg") no-repeat center;
      background-size: cover;
    }

    .main-section-2 {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      margin-bottom: 3.75rem;
      
    }
    .main-section-2-container {
      max-width: 69.625rem;
      display: grid;
      grid-template-columns: repeat(9,1fr);
      grid-template-rows: 10rem;
    }
    .main-section-2-container-img {
      grid-column-start: 1;
      grid-column-end: 5;
      grid-row-start: 1;
      grid-row-end:-1;
      width: 28.14294rem;
    }
    .main-section-2-container-article {
       grid-column-start: 4;
      grid-column-end: -1;
       grid-row-start: 2;
      grid-row-end: -1;
      display: flex;
      flex-flow: column nowrap;
      align-items: start;
      gap: 2rem;
      max-width: 45.625rem;
      padding: 4rem;
      background-color: var(--DarkPurple);
      
    }

    .main-section-2-container-h2,
    .main-section-2-container-p {
      color: var(--white);
    }

    .main-section-2-container-h2 {
      font-family: Fraunces 144pt;
      font-size: 3.5rem;
      font-weight: 600;
      line-height: 4rem;
    }
    .main-section-2-container-p {
      font-family: Manrope;
      font-size: 1.125rem;
      font-weight: 400;
      line-height: 2rem;
    }

    .main-section-2-pattern{
      position: absolute;
      width: 10.8125rem;
      right: 17.5%;
      bottom: -40px;
    }
  </style>
</main>
